		<outline text="June 2021" type="calendarMonth" name="june2021" >
			<outline text="June 30" type="calendarDay" name="30" >
				<outline text="I bet people my age can name at least half of these folks, even in a weak resolution image... https://t.co/AjJAW5icqa" type="tweet" created="Wed, 30 Jun 2021 23:59:02 GMT" tweetId="1410387432781066241" urltweet="https://twitter.com/KenSmith/status/1410387432781066241" inReplyToId="" tweetUserName="KenSmith" />
