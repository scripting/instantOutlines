		<outline text="July 2021" type="calendarMonth" name="july2021" >
			<outline text="July 28" type="calendarDay" name="28" >
				<outline text="MERIDIAN HEIGHTS APARTMENTS in #SANDY #Utah has total disregard for its elderly residents. NO AC for days. No running water. EXORBITANT RENT. @KSLmatt this is a STORY FOR YOU! I promise this is just one example of many in the #SLC valley." type="tweet" created="Wed, 28 Jul 2021 20:17:18 GMT" tweetId="1420478492261584897" urltweet="https://twitter.com/nakedjen/status/1420478492261584897" inReplyToId="" tweetUserName="nakedjen" />
				</outline>
