			<outline text="July 22" type="calendarDay" name="22" >
				<outline text="The FBI’s ‘investigation’ of Kavanaugh was laughable. &lt;a href=&quot;https://www.washingtonpost.com/opinions/2021/07/22/fbis-investigation-kavanaugh-is-laughable/&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Fri, 23 Jul 2021 00:53:36 GMT" tweetId="1418373697606406146" urltweet="https://twitter.com/davewiner/status/1418373697606406146" tweetUserName="davewiner" />
