			<outline text="July 7" type="calendarDay" name="07" >
				<outline text="New York Mets ace Jacob deGrom says he's skipping All-Star Game. &lt;a href=&quot;https://www.espn.com/mlb/story/_/id/31778507/new-york-mets-ace-jake-degrom-says-skipping-all-star-game&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 08 Jul 2021 02:39:33 GMT" tweetId="1412964545128239114" urltweet="https://twitter.com/davewiner/status/1412964545128239114" inReplyToId="" tweetUserName="davewiner" />
				<outline text="Bear pulls woman out of her tent, kills her in Montana. &lt;a href=&quot;https://apnews.com/article/wy-state-wire-mt-state-wire-id-state-wire-montana-environment-and-nature-b97b23f04ec5e7689d660a0e3a9483af?utm_campaign=SocialFlow&amp;utm_source=Twitter&amp;utm_medium=AP&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 08 Jul 2021 02:35:08 GMT" tweetId="1412963430928158720" urltweet="https://twitter.com/davewiner/status/1412963430928158720" inReplyToId="" tweetUserName="davewiner" />
				<outline text="The Professional Audio Manufacturers Alliance industry group is leading an effort to finally get rid of “male” and “female” connector terminology and replace it with something not horrible. &lt;a href=&quot;https://cdm.link/2021/07/so-yeah-lets-just-use-plug-and-socket-industry-group-recommends-obvious-change-in-terminology/?fbclid=IwAR2aR5hlMIYWgLr8kuxdNXC432EVJB0T6PJbvlDcTo1476NmT3HZTI20CU4&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 08 Jul 2021 02:08:56 GMT" tweetId="1412956837197012992" urltweet="https://twitter.com/davewiner/status/1412956837197012992" inReplyToId="" tweetUserName="davewiner" />
				<outline text="I'm going to keep on keeping on if you don't mind." type="tweet" created="Wed, 07 Jul 2021 20:35:25 GMT" tweetId="1412872904857899011" urltweet="https://twitter.com/davewiner/status/1412872904857899011" inReplyToId="" tweetUserName="davewiner" />
				<outline text="No one understands you. Now what?" type="tweet" created="Wed, 07 Jul 2021 20:34:28 GMT" tweetId="1412872668907507723" urltweet="https://twitter.com/davewiner/status/1412872668907507723" inReplyToId="" tweetUserName="davewiner" />
				<outline text="You don't really think I'm tweeting about you, do you?" type="tweet" created="Wed, 07 Jul 2021 20:34:09 GMT" tweetId="1412872587198308362" urltweet="https://twitter.com/davewiner/status/1412872587198308362" inReplyToId="" tweetUserName="davewiner" />
				<outline text="Are you sure no one has it as bad as you?" type="tweet" created="Wed, 07 Jul 2021 20:33:52 GMT" tweetId="1412872516863995906" urltweet="https://twitter.com/davewiner/status/1412872516863995906" inReplyToId="" tweetUserName="davewiner" />
				<outline text="Why do you argue with people if you do?" type="tweet" created="Wed, 07 Jul 2021 20:33:25 GMT" tweetId="1412872402233610251" urltweet="https://twitter.com/davewiner/status/1412872402233610251" inReplyToId="" tweetUserName="davewiner" />
				<outline text="Are you trying to get ahead?" type="tweet" created="Wed, 07 Jul 2021 20:30:42 GMT" tweetId="1412871718499192833" urltweet="https://twitter.com/davewiner/status/1412871718499192833" inReplyToId="" tweetUserName="davewiner" />
