			<outline text="June 25" type="calendarDay" name="25" >
				<outline text="Watched this 1993 Simpsons and was not prepared for the punchline! https://t.co/390Gl9VXNB" type="tweet" created="Fri, 25 Jun 2021 21:51:43 GMT" tweetId="1408543453366022149" urltweet="https://twitter.com/sarahkendzior/status/1408543453366022149" tweetUserName="sarahkendzior" >
