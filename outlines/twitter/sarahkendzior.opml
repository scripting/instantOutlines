			<outline text="June 11" type="calendarDay" name="11" >
				<outline text="&quot;In Missouri, we meet many of the metrics for a failed state. Failed states have limited resources, a lack of democracy, great income inequality, failing education systems, a legislative takeover that gerrymandered away the political opposition...&quot; https://t.co/YgZqdkmDpB" type="tweet" created="Fri, 11 Jun 2021 16:17:50 GMT" tweetId="1403385998185271303" urltweet="https://twitter.com/sarahkendzior/status/1403385998185271303" inReplyToId="" tweetUserName="sarahkendzior" />
