			<outline text="July 5" type="calendarDay" name="05" >
				<outline text="At the Abraham Lincoln Presidential Library in Springfield there are now museum exhibits on Cheap Trick, Richard Marx, Ministry, and Styx &lt;a href=&quot;https://twitter.com/sarahkendzior/status/1412127219686780929/photo/1&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Mon, 05 Jul 2021 19:12:19 GMT" tweetId="1412127219686780929" urltweet="https://twitter.com/sarahkendzior/status/1412127219686780929" tweetUserName="sarahkendzior" >
