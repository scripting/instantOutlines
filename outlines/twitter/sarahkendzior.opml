			<outline text="June 24" type="calendarDay" name="24" >
				<outline text="I've watched this more than any other movie in my life and I have no regrets! https://t.co/2QeGwrdsAT" type="tweet" created="Thu, 24 Jun 2021 22:01:00 GMT" tweetId="1408183402570911745" urltweet="https://twitter.com/sarahkendzior/status/1408183402570911745" tweetUserName="sarahkendzior" >
