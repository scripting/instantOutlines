			<outline text="June 13" type="calendarDay" name="13" >
				<outline text="Thread https://t.co/pkovuR017o" type="tweet" created="Sun, 13 Jun 2021 15:59:48 GMT" tweetId="1404106238300991494" urltweet="https://twitter.com/sarahkendzior/status/1404106238300991494" tweetUserName="sarahkendzior" />
