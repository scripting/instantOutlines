				<outline text="Thread https://t.co/wvXHD9eJKT" type="tweet" created="Sun, 27 Jun 2021 21:28:38 GMT" tweetId="1409262418748903428" urltweet="https://twitter.com/sarahkendzior/status/1409262418748903428" tweetUserName="sarahkendzior" />
