					<outline text="@CillaAguirre &quot;When I figured out there are no content houses in Texas, especially a bilingual one, I knew I had to start this project... We want to show representation in the content world and have it based in Texas.&quot; &lt;a href=&quot;https://www.mysanantonio.com/lifestyle/article/Meet-bilingual-content-house-in-Texas-Tejas-16352183.php&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Mon, 02 Aug 2021 15:33:41 GMT" tweetId="1422219056900280327" urltweet="https://twitter.com/taylorlorenz/status/1422219056900280327" inReplyToId="1422218896296218628" tweetUserName="taylorlorenz" />
