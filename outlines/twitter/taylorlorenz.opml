		<outline text="August 2021" type="calendarMonth" name="august2021" >
			<outline text="August 10" type="calendarDay" name="10" >
				<outline text="!!!!!!!!! This is amazing!! Can't wait to read every single thing @SafyHallanFarah writes for TechCrunch &lt;a href=&quot;https://twitter.com/SafyHallanFarah/status/1425153076839829506&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Tue, 10 Aug 2021 23:28:25 GMT" tweetId="1425237630803857419" urltweet="https://twitter.com/taylorlorenz/status/1425237630803857419" inReplyToId="" tweetUserName="taylorlorenz" />
				<outline text="😊😊😊 &lt;a href=&quot;https://www.wsj.com/articles/sending-a-smiley-face-make-sure-you-know-what-youre-saying-11628522840&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Tue, 10 Aug 2021 14:59:46 GMT" tweetId="1425109626119364609" urltweet="https://twitter.com/taylorlorenz/status/1425109626119364609" inReplyToId="" tweetUserName="taylorlorenz" />
				<outline text="Reading this piece put the 🎶apple bottom jeans 🎶 back in my head &lt;a href=&quot;https://www.vox.com/the-goods/22617328/on-a-downward-spiral-instagram-meme-shitpost-chaos-edit&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Tue, 10 Aug 2021 14:07:36 GMT" tweetId="1425096497406820371" urltweet="https://twitter.com/taylorlorenz/status/1425096497406820371" inReplyToId="" tweetUserName="taylorlorenz" />
				<outline text="What is the city in the US least likely to be affected by climate change and why?" type="tweet" created="Tue, 10 Aug 2021 13:51:26 GMT" tweetId="1425092429368152071" urltweet="https://twitter.com/taylorlorenz/status/1425092429368152071" inReplyToId="" tweetUserName="taylorlorenz" />
				<outline text="“If you get a job, I’ll come after your wages. If you get married, I’ll go after your joint bank account. I will come after you for the rest of your life,” she said he told her &lt;a href=&quot;https://www.nytimes.com/2021/08/09/style/rachel-uchitel-tiger-woods-nda.html&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Tue, 10 Aug 2021 13:14:16 GMT" tweetId="1425083075172569089" urltweet="https://twitter.com/taylorlorenz/status/1425083075172569089" inReplyToId="" tweetUserName="taylorlorenz" />
				<outline text="Going to bed knowing I accomplished something today 😌 &lt;a href=&quot;https://twitter.com/nyt_first_said/status/1424748410905759753&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Tue, 10 Aug 2021 04:22:46 GMT" tweetId="1424949319635849218" urltweet="https://twitter.com/taylorlorenz/status/1424949319635849218" inReplyToId="" tweetUserName="taylorlorenz" />
				<outline text="Respectfully asking Netflix to add 144 more horror movies to the platform so I can make it through the rest of the year" type="tweet" created="Tue, 10 Aug 2021 04:10:48 GMT" tweetId="1424946308486291458" urltweet="https://twitter.com/taylorlorenz/status/1424946308486291458" inReplyToId="" tweetUserName="taylorlorenz" >
					<outline text="I've watched everything on Shudder too at this point" type="tweet" created="Tue, 10 Aug 2021 04:11:31 GMT" tweetId="1424946487423688704" urltweet="https://twitter.com/taylorlorenz/status/1424946487423688704" inReplyToId="1424946308486291458" tweetUserName="taylorlorenz" >
						<outline text="This list is like a year and a half old but I made this spreadsheet of some of my horror movie recs! &lt;a href=&quot;https://docs.google.com/spreadsheets/d/15V9Y7jKTTHgMtowUl-nFDVWDvbsePdggUv5Th3mEERY/edit#gid=0&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Tue, 10 Aug 2021 04:16:37 GMT" tweetId="1424947771258245120" urltweet="https://twitter.com/taylorlorenz/status/1424947771258245120" inReplyToId="1424946487423688704" tweetUserName="taylorlorenz" />
