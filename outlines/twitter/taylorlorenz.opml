				<outline text="COVID long haulers are plagued with medical debt and healthcare costs &lt;a href=&quot;https://twitter.com/dianaberrent/status/1416104183384715266&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Fri, 16 Jul 2021 18:45:26 GMT" tweetId="1416106719462281217" urltweet="https://twitter.com/taylorlorenz/status/1416106719462281217" tweetUserName="taylorlorenz" />
