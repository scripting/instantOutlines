	<body>
		<outline text="July 2021" type="calendarMonth" name="july2021" >
			<outline text="July 26" type="calendarDay" name="26" >
				<outline text="Hello everybody. This is the @cluelessnewbie." type="tweet" created="Mon, 26 Jul 2021 22:16:10 GMT" tweetId="1419783631703322631" urltweet="https://twitter.com/cluelessnewbie/status/1419783631703322631" inReplyToId="" tweetUserName="cluelessnewbie" />
				<outline text="greetings once again from @cluelessnewbie" type="tweet" created="Mon, 26 Jul 2021 18:50:51 GMT" tweetId="1419731962978349061" urltweet="https://twitter.com/cluelessnewbie/status/1419731962978349061" inReplyToId="" tweetUserName="cluelessnewbie" />
				<outline text="This may become the developer support channel on Twitter for OPML developers." type="tweet" created="Mon, 26 Jul 2021 16:32:14 GMT" tweetId="1419697076187844610" urltweet="https://twitter.com/cluelessnewbie/status/1419697076187844610" inReplyToId="" tweetUserName="cluelessnewbie" >
					<outline text="In the meantime it's turning into a very convenient place to post messages for testing." type="tweet" created="Mon, 26 Jul 2021 16:37:36 GMT" tweetId="1419698427152195587" urltweet="https://twitter.com/cluelessnewbie/status/1419698427152195587" inReplyToId="1419697076187844610" tweetUserName="cluelessnewbie" >
						<outline text="the calling conventions for opml.parse are different on server and in-browser. due to a design mistake elsewhere. oy." type="tweet" created="Mon, 26 Jul 2021 16:40:40 GMT" tweetId="1419699200481234946" urltweet="https://twitter.com/cluelessnewbie/status/1419699200481234946" inReplyToId="1419698427152195587" tweetUserName="cluelessnewbie" >
							<outline text="every mistake i make is apple's fault. ;-)" type="tweet" created="Mon, 26 Jul 2021 16:43:33 GMT" tweetId="1419699924078374915" urltweet="https://twitter.com/cluelessnewbie/status/1419699924078374915" inReplyToId="1419699200481234946" tweetUserName="cluelessnewbie" >
								<outline text="oy i'm fixing stuff all over the place. my code is working better. oy yeah." type="tweet" created="Mon, 26 Jul 2021 16:48:25 GMT" tweetId="1419701151356837889" urltweet="https://twitter.com/cluelessnewbie/status/1419701151356837889" inReplyToId="1419699924078374915" tweetUserName="cluelessnewbie" >
									<outline text="fart is going on here" type="tweet" created="Mon, 26 Jul 2021 16:54:23 GMT" tweetId="1419702652099825664" urltweet="https://twitter.com/cluelessnewbie/status/1419702652099825664" inReplyToId="1419701151356837889" tweetUserName="cluelessnewbie" />
									</outline>
								<outline text="ok someting yust worked" type="tweet" created="Mon, 26 Jul 2021 16:50:10 GMT" tweetId="1419701590861221892" urltweet="https://twitter.com/cluelessnewbie/status/1419701590861221892" inReplyToId="1419699924078374915" tweetUserName="cluelessnewbie" >
									<outline text="not sure if it's working, which means it probably isn't" type="tweet" created="Mon, 26 Jul 2021 16:51:49 GMT" tweetId="1419702006751670275" urltweet="https://twitter.com/cluelessnewbie/status/1419702006751670275" inReplyToId="1419701590861221892" tweetUserName="cluelessnewbie" />
									</outline>
								</outline>
							</outline>
						</outline>
					</outline>
				<outline text="New rule in general.

When notifying about changes to instant outlines, always use the value of urlPublic in the head section of the OPML.

Both to notify and be notified.

This way we don't get our signals crossed, as was happening." type="tweet" created="Mon, 26 Jul 2021 16:26:00 GMT" tweetId="1419695506649985028" urltweet="https://twitter.com/cluelessnewbie/status/1419695506649985028" inReplyToId="" tweetUserName="cluelessnewbie" />
				<outline text="Still testing at 11:56AM." type="tweet" created="Mon, 26 Jul 2021 15:55:07 GMT" tweetId="1419687738299781120" urltweet="https://twitter.com/cluelessnewbie/status/1419687738299781120" inReplyToId="" tweetUserName="cluelessnewbie" />
				<outline text="Hi this is Dave here. I'm using this account to test I/Oing in Drummer." type="tweet" created="Mon, 26 Jul 2021 15:25:50 GMT" tweetId="1419680367628505094" urltweet="https://twitter.com/cluelessnewbie/status/1419680367628505094" inReplyToId="" tweetUserName="cluelessnewbie" />
				</outline>
