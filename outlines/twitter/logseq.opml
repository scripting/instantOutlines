			<outline text="July 22" type="calendarDay" name="22" >
				<outline text="How to use @Replit and @vercel to publish your Logseq notes? &lt;a href=&quot;https://www.youtube.com/watch?v=JVhGmpP4qpo&amp;ab_channel=PrashantSengar&quot;&gt;[link]&lt;/a&gt;
Shared by @prashanttgs 💯
https://t.co/OO4dFkjOSw" type="tweet" created="Thu, 22 Jul 2021 04:39:16 GMT" tweetId="1418068103032754179" urltweet="https://twitter.com/logseq/status/1418068103032754179" tweetUserName="logseq" />
				<outline text="Memory fades, let me introduce the SRS cards! &lt;a href=&quot;https://twitter.com/logseq/status/1418237564515864580/photo/1&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 22 Jul 2021 15:52:39 GMT" tweetId="1418237564515864580" urltweet="https://twitter.com/logseq/status/1418237564515864580" tweetUserName="logseq" />
				<outline text="You can create some clozes too! &lt;a href=&quot;https://twitter.com/logseq/status/1418238165303713792/photo/1&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 22 Jul 2021 15:55:02 GMT" tweetId="1418238165303713792" urltweet="https://twitter.com/logseq/status/1418238165303713792" tweetUserName="logseq" />
				<outline text="0.2.7 is just out! &lt;a href=&quot;https://twitter.com/logseq/status/1418237694535094272/photo/1&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 22 Jul 2021 15:53:10 GMT" tweetId="1418237694535094272" urltweet="https://twitter.com/logseq/status/1418237694535094272" tweetUserName="logseq" />
