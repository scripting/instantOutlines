			<outline text="April 11" type="calendarDay" name="11" >
				<outline text="For some strange reason, in past weeks I've once again become enamored of this little device given to me by @jallard &lt;a href=&quot;https://twitter.com/rozzie/status/1381282430707990529/photo/1&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Sun, 11 Apr 2021 16:26:09 GMT" tweetId="1381282430707990529" urltweet="https://twitter.com/rozzie/status/1381282430707990529" tweetUserName="rozzie" />
