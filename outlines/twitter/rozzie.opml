			<outline text="April 18" type="calendarDay" name="18" >
				<outline text="Beast Mode is wicked-eloquent in framing the issues. Well worth watching. &lt;a href=&quot;https://twitter.com/deanhach/status/1383828745149050884&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Sun, 18 Apr 2021 17:55:10 GMT" tweetId="1383841550807945218" urltweet="https://twitter.com/rozzie/status/1383841550807945218" tweetUserName="rozzie" />
