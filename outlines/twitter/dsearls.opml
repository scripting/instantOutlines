			<outline text="August 5" type="calendarDay" name="05" >
				<outline text="It was great having you on. A milestone! Weâll have you back for an anniversary of the show. &lt;a href=&quot;https://twitter.com/openanniv/status/1423101876413812740&quot;&gt;[link]&lt;/a&gt;" type="tweet" created="Thu, 05 Aug 2021 19:17:50 GMT" tweetId="1423362631700684802" urltweet="https://twitter.com/dsearls/status/1423362631700684802" inReplyToId="" tweetUserName="dsearls" />
