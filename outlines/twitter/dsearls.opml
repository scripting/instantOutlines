		<outline text="August 2021" type="calendarMonth" name="august2021" >
			<outline text="August 20" type="calendarDay" name="20" >
				<outline text="Thanks to expert guidance by @ccarfi and his awesome @worpress fu, comments are again supported on my blog, &lt;a href=&quot;https://blogs.harvard.edu/doc/&quot;&gt;[link]&lt;/a&gt;. This increases the risk that I'll go back to blogging daily there." type="tweet" created="Fri, 20 Aug 2021 21:24:14 GMT" tweetId="1428830257520463875" urltweet="https://twitter.com/dsearls/status/1428830257520463875" inReplyToId="" tweetUserName="dsearls" />
