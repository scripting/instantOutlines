			<outline text="August 16" type="calendarDay" name="16" >
				<outline text="Who is the female voice backing Arlo Guthrie in âCity of New Orleans?â Just wondering." type="tweet" created="Tue, 17 Aug 2021 01:51:03 GMT" tweetId="1427447853060919296" urltweet="https://twitter.com/dsearls/status/1427447853060919296" inReplyToId="" tweetUserName="dsearls" />
