							</outline>
						<outline text="&lt;/head&gt;"/>
						</outline>
					<outline text="&lt;body&gt;">
						<outline text="&lt;div class=&quot;divPageBody&quot;&gt;">
							<outline text="&lt;h1&gt;Socket Client&lt;/h1&gt;" created="Sun, 28 Mar 2021 16:28:12 GMT"/>
							<outline text="&lt;p&gt;This is the demo app for &lt;a href=&quot;https://github.com/scripting/instantOutlines&quot;&gt;Instant Outlines&lt;/a&gt;. It's showing &lt;a href=&quot;https://twitter.com/davewiner&quot;&gt;my tweets&lt;/a&gt; in a calendar structured outline. Automatically updates when something new is posted. Organizes threads using the hierarchy. View the OPML &lt;a id=&quot;idOpmlLink&quot;&gt;here&lt;/a&gt;. The head info is at the &lt;a href=&quot;#headElements&quot;&gt;bottom&lt;/a&gt; of this page. Dave Winer, 6/12/2021&lt;/p&gt;" created="Thu, 10 Jun 2021 12:23:02 GMT"/>
							<outline text="&lt;div class=&quot;divOutlineViewer&quot; id=&quot;idOutlineViewer&quot;&gt;" created="Thu, 10 Jun 2021 16:58:57 GMT">
								<outline text="&lt;/div&gt;" created="Thu, 10 Jun 2021 16:59:03 GMT"/>
								</outline>
							<outline text="&lt;a name=&quot;headElements&quot;&gt;&lt;/a&gt;" created="Fri, 11 Jun 2021 12:25:24 GMT"/>
							<outline text="&lt;div class=&quot;divHeadElementsViewer&quot; id=&quot;idHeadElementsViewer&quot;&gt;" created="Thu, 10 Jun 2021 16:58:57 GMT">
								<outline text="&lt;/div&gt;" created="Thu, 10 Jun 2021 16:59:03 GMT"/>
								</outline>
							<outline text="&lt;div class=&quot;divOutlinerContainer&quot;&gt;" isComment="true">
								<outline text="&lt;div id=&quot;outliner&quot;&gt;">
									<outline text="&lt;/div&gt;"/>
									</outline>
								<outline text="&lt;/div&gt;"/>
								</outline>
